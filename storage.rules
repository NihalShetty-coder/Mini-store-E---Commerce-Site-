rules_version = '2';

// secure the firebase storage bucket
service firebase.storage {
  match /b/{bucket}/o {
    
    // Check if user is an admin by querying Firestore admins collection only.
    // NOTE: We do NOT fall back to users/{uid}.role because users can write their own
    // profile documents, which would allow privilege escalation.
    function isAdmin() {
      return firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
    
    // Validate image file (5MB max)
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024 &&
             request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
    }
    
    // Validate video file (50MB max)
    function isValidVideo() {
      return request.resource.size < 50 * 1024 * 1024 &&
             request.resource.contentType.matches('video/(mp4|webm|quicktime|x-msvideo)');
    }

    // Product images - admins can upload, everyone can read
    match /products/images/{imageId} {
      allow read: if true; // Public read for all product images
      allow write: if request.auth != null && isAdmin() && isValidImage();
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Product videos - admins can upload, everyone can read
    match /products/videos/{videoId} {
      allow read: if true; // Public read for all product videos
      allow write: if request.auth != null && isAdmin() && isValidVideo();
      allow delete: if request.auth != null && isAdmin();
    }

    // Default deny for all other paths (except public reads)
    match /{allPaths=**} {
      allow read: if true; 
      // Block all writes by default - only explicit product paths above allow writes
      allow write: if false;
      allow delete: if false;
    }
  }
}
