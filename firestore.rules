rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is an admin
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'nihalnshetty42@gmail.com' ||
              exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    // Products: anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Orders
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if true; 
      allow update, delete: if isAdmin();
    }
    
    // Users
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
    
    // Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins Collection
    match /admins/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if false; 
    }

    // Analytics events: anyone can create, only admins can read/delete
    match /analytics_events/{eventId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // Wishlists: each user owns their own sub-collection
    match /wishlists/{userId}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
